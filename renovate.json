{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "kubernetes",
    "kustomize",
    "helm-values",
    "terraform"
  ],
  "packageRules": [
    {
      "description": "Use OpenTofu registry for all Terraform/OpenTofu resources",
      "matchDatasources": ["terraform-provider", "terraform-module"],
      "registryUrls": ["https://registry.opentofu.org"]
    }
  ],
  "terraform": {
    "enabled": true,
    "managerFilePatterns": [
      "**/*.tf",
      "**/*.tofu"
    ]
  },
  "kustomize": {
    "managerFilePatterns": [
      "/(^|/)kustomization\\.ya?ml(\\.j2)?$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/).+\\.(ya?ml)$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/).*/values(-.*)?\\.ya?ml$/"
    ]
  }
}
